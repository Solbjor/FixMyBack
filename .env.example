PORT=3000

# Firebase Web API Key — found in Firebase Console > Project Settings > General > Web API Key
# This is NOT the service account key; it's the client-facing API key used for sign-in.
FIREBASE_WEB_API_KEY=your_web_api_key_here

# GCP Cloud SQL (PostgreSQL) connection string
# Format: postgresql://USER:PASSWORD@HOST:5432/DATABASE
# Via Cloud SQL Auth Proxy (recommended): postgresql://USER:PASSWORD@127.0.0.1:5432/DATABASE
# Via Cloud SQL socket: postgresql://USER:PASSWORD@localhost/DATABASE?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql://user:password@host:5432/database
